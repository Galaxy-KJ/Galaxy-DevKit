{
  "name": "@galaxy-kj/core-test-utils",
  "version": "1.0.0",
  "description": "Galaxy DevKit — shared integration-test helpers (Friendbot funding, tx helpers, contract fixtures)",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "test": "jest --config jest.config.cjs --runInBand",
