{
  "name": "@galaxy-kj/core",
  "version": "5.0.0",
  "description": "Galaxy DevKit core library — CLI wallet management",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./cli/wallet-store": {
      "types": "./dist/src/cli/wallet-store.d.ts",
      "import": "./dist/src/cli/wallet-store.js"
    },
    "./cli/commands/wallet": {
      "types": "./dist/src/cli/commands/wallet.d.ts",
      "import": "./dist/src/cli/commands/wallet.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^14.5.0",
    "commander": "^12.0.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^8.2.6",
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^8.2.10",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.5",
    "typescript": "^5.8.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
