{
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": "../../../",
    "rootDir": ".",
    "outDir": "./dist",
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@galaxy-kj/core-wallet": ["packages/core/wallet/src/index.ts"],
      "@galaxy-kj/core-wallet/*": ["packages/core/wallet/src/*"],
      "@galaxy-kj/core-stellar-sdk": ["packages/core/stellar-sdk/dist/stellar-sdk/src/index.d.ts"],
      "@galaxy-kj/core-stellar-sdk/soroban": ["packages/core/stellar-sdk/dist/stellar-sdk/src/soroban/index.d.ts"],
      "@galaxy-kj/core-stellar-sdk/*": ["packages/core/stellar-sdk/dist/stellar-sdk/src/*"],
      "@galaxy-kj/core-defi-protocols": ["packages/core/defi-protocols/src/index.ts"],
      "@galaxy-kj/core-defi-protocols/*": ["packages/core/defi-protocols/src/*"],
      "@galaxy-kj/core-oracles": ["packages/core/oracles/dist/index.d.ts"],
      "@galaxy-kj/core-oracles/*": ["packages/core/oracles/dist/*"],
      "@galaxy-kj/core-defi": ["packages/core/defi/src/index.ts"],
      "@galaxy-kj/core-defi/*": ["packages/core/defi/src/*"],
      "@galaxy-kj/core-invisible-wallet": ["packages/core/invisible-wallet/dist/invisible-wallet/index.d.ts"],
      "@galaxy-kj/core-invisible-wallet/*": ["packages/core/invisible-wallet/dist/invisible-wallet/src/*"],
      "@galaxy-kj/core-automation": ["packages/core/automation/src/index.ts"],
      "@galaxy-kj/core-automation/*": ["packages/core/automation/src/*"]
    }
  },
  "include": ["index.ts", "src/**/*"],
  "exclude": ["node_modules", "dist", "__tests__"]
}
