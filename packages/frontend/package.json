{
  "name": "@galaxy-kj/frontend",
  "version": "1.0.0",
  "description": "Vite playground for Galaxy DevKit smart wallets, Stellar SDK flows, and browser integration testing",
  "private": true,
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 5173",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@galaxy-kj/core-stellar-sdk": "^5.0.2",
    "@stellar/stellar-sdk": "^14.6.1",
    "buffer": "^6.0.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0",
    "vite": "^5.4.14"
  }
}
