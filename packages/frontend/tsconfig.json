{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "strict": true,
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["vite/client", "jest", "node"],
    "baseUrl": ".",
    "paths": {
      "@galaxy-kj/core-wallet": ["../core/wallet/src/index.ts"],
      "@galaxy-kj/core-stellar-sdk": ["../core/stellar-sdk/src/browser.ts"],
      "@galaxy-kj/core-defi-protocols": ["../core/defi-protocols/src"],
      "@galaxy-kj/core-oracles": ["../core/oracles/src"],
      "@galaxy-kj/core-defi": ["../core/defi/src"],
      "@galaxy-kj/core-invisible-wallet": ["../core/invisible-wallet/src"],
      "@stellar/stellar-sdk/rpc": ["./node_modules/@stellar/stellar-sdk/lib/rpc/index.d.ts"]
    }
  },
  "include": ["src/**/*", "vite.config.ts"],
  "exclude": ["node_modules", "dist", "coverage"]
}
