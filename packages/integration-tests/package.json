{
  "name": "@galaxy-kj/integration-tests",
  "version": "1.0.0",
  "description": "Galaxy DevKit integration tests — covers DeFi protocols, oracle systems, and Stellar SDK extensions",
  "private": true,
  "scripts": {
    "test:integration": "jest --config jest.config.cjs --runInBand --forceExit",
    "test:integration:watch": "jest --config jest.config.cjs --runInBand --watch",
    "test:integration:verbose": "jest --config jest.config.cjs --runInBand --forceExit --verbose"
  },
  "dependencies": {
    "@blend-capital/blend-sdk": "^3.2.2",
    "@galaxy-kj/core-defi-protocols": "*",
    "@galaxy-kj/core-oracles": "*",
    "@galaxy-kj/core-stellar-sdk": "*",
    "@galaxy-kj/core-wallet": "*",
    "@stellar/stellar-sdk": "^14.4.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.5",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "stellar",
    "integration-tests",
    "defi",
    "oracles",
    "galaxy"
  ],
  "author": "Galaxy DevKit Team",
